# ─────────────────────────────────────────────────────────────────────
# IndOS — Example Environment Configuration
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────

# ── Core (REQUIRED) ───────────────────────────────────────────────────
# Database — Neon Postgres (production) or SQLite (dev)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
# DATABASE_URL="file:./db/indos.db"

# NextAuth session secret — REQUIRED in production (app refuses to start without it).
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-random-32-char-string"

# Public URL of the deployment (auto-detected behind proxy; set explicitly if redirect issues)
# NEXTAUTH_URL="https://your-domain.com"

# ── OTA Firmware Signing (Ed25519) ────────────────────────────────────
# Generate with: bunx tsx scripts/generate-ota-keys.ts
# Private key stays server-side ONLY. Public key goes in ESP32 firmware.
OTA_SIGNING_PRIVATE_KEY=""
OTA_SIGNING_PUBLIC_KEY=""
OTA_SIGNING_KEY_ID="key-001"

# ── Optional backing services (dev works without these) ───────────────

# InfluxDB — historical telemetry persistence (90d raw / 365d downsampled)
# Without it: live stream works, queries fall back to SQLite
# INFLUX_URL="http://localhost:8086"
# INFLUX_TOKEN=""
# INFLUX_ORG="indos"
# INFLUX_BUCKET="telemetry"

# Redis — shared cache + future rate-limit backend
# Without it: in-memory LRU (500 entries, single-instance only)
# REDIS_URL="redis://localhost:6379"

# OpenRouter — AI Center copilot (POST /api/indos/ai)
# Without it: AI Center returns error; rest of platform unaffected
# OPENROUTER_API_KEY=""

# Manas — AI fallback provider
# MANAS_API_KEY=""

# Wasabi S3 — firmware binary storage
# WASABI_ACCESS_KEY=""
# WASABI_SECRET_KEY=""
# WASABI_ENDPOINT="https://s3.wasabisys.com"
# WASABI_BUCKET="indos-firmware"

# Firecrawl — web scraping for intelligence/reports
# FIRECRAWL_API_KEY=""

# ── Production deployment notes ───────────────────────────────────────
# 1. Run `bunx prisma db push` once after first boot to create schema
# 2. Run `bunx tsx prisma/seed.ts` once to seed admin + demo data
# 3. Default admin: admin@indos.io / indos123 — CHANGE PASSWORD after login
# 4. Generate OTA keys before registering firmware
# 5. Set NEXTAUTH_SECRET to a random 32+ char string (NOT the dev default)
