{
  "mcpServers": {
    "firecrawl": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      }
    },
    "supabase": {
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server-supabase", "--access-token", "${SUPABASE_ACCESS_TOKEN}"],
      "env": {}
    },
    "render": {
      "command": "npx",
      "args": ["-y", "@renderinc/mcp-server-render", "--api-key", "${RENDER_API_KEY}"],
      "env": {}
    },
    "vercel": {
      "command": "npx",
      "args": ["-y", "@vercel/mcp-adapter", "--token", "${VERCEL_TOKEN}"],
      "env": {}
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/home/z/my-project"],
      "env": {}
    }
  }
}
